    "customColumn2": {
      "alias": "Performance",
      "allowCellWrapping": false,
      "allowSameOptionsInNewRow": true,
      "buttonStyle": "rgb(3, 179, 101)",
      "columnType": "html",
      "computedValue": "{{(() => { const tableData = Job_List.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => (\n  (() => {\n    const score = Number(currentRow.scores_complexity_v2) || 0;\n    const percent = score > 0 ? Math.round((score / 5) * 100) : 0;\n    \n    // Berechne Tage seit job_slot_redeemed_at\n    const redeemedAt = currentRow.job_slot_redeemed_at;\n    let daysSinceRedeemed = 0;\n    \n    if (redeemedAt) {\n      const redeemedDate = new Date(redeemedAt);\n      const today = new Date();\n      daysSinceRedeemed = Math.floor((today - redeemedDate) / (1000 * 60 * 60 * 24));\n    }\n    \n    const isLearning = daysSinceRedeemed < 6;\n\n    // Farben 1=rot → 5=grün\n    const colors = {1:'#ea4335', 2:'#ff9800', 3:'#fbbc04', 4:'#8bc34a', 5:'#22b31e'};\n    const color = colors[score] || '#e0e0e0';\n\n    if (isLearning) {\n      return `\n        <div style=\"display:flex; align-items:center; gap:6px;\">\n          <span style=\"font-size:14px; line-height:1;\">⏳</span>\n          <span style=\"font-size:12px; color:#555;\">Lernt noch</span>\n        </div>\n      `;\n    }\n\n    // Sonst: normaler Balken\n    return `\n      <div style=\"display:flex; align-items:center; gap:8px; min-width:50px;\">\n        <div style=\"flex:1; height:10px; background:#eee; border-radius:6px; overflow:hidden;\">\n          <div style=\"height:100%; width:${percent}%; background:${color}; transition:width .3s;\"></div>\n        </div>\n        <div style=\"min-width:20px; font-size:12px; color:#333; text-align:right;\">${score || ''}</div>\n      </div>\n    `;\n  })()\n)) : \n  (() => {\n    const score = Number(currentRow.scores_complexity_v2) || 0;\n    const percent = score > 0 ? Math.round((score / 5) * 100) : 0;\n    \n    // Berechne Tage seit job_slot_redeemed_at\n    const redeemedAt = currentRow.job_slot_redeemed_at;\n    let daysSinceRedeemed = 0;\n    \n    if (redeemedAt) {\n      const redeemedDate = new Date(redeemedAt);\n      const today = new Date();\n      daysSinceRedeemed = Math.floor((today - redeemedDate) / (1000 * 60 * 60 * 24));\n    }\n    \n    const isLearning = daysSinceRedeemed < 6;\n\n    // Farben 1=rot → 5=grün\n    const colors = {1:'#ea4335', 2:'#ff9800', 3:'#fbbc04', 4:'#8bc34a', 5:'#22b31e'};\n    const color = colors[score] || '#e0e0e0';\n\n    if (isLearning) {\n      return `\n        <div style=\"display:flex; align-items:center; gap:6px;\">\n          <span style=\"font-size:14px; line-height:1;\">⏳</span>\n          <span style=\"font-size:12px; color:#555;\">Lernt noch</span>\n        </div>\n      `;\n    }\n\n    // Sonst: normaler Balken\n    return `\n      <div style=\"display:flex; align-items:center; gap:8px; min-width:50px;\">\n        <div style=\"flex:1; height:10px; background:#eee; border-radius:6px; overflow:hidden;\">\n          <div style=\"height:100%; width:${percent}%; background:${color}; transition:width .3s;\"></div>\n        </div>\n        <div style=\"min-width:20px; font-size:12px; color:#333; text-align:right;\">${score || ''}</div>\n      </div>\n    `;\n  })()\n })()}}",
      "currencyCode": "USD",
      "decimals": 0,
      "enableFilter": true,
      "enableSort": true,
      "horizontalAlignment": "LEFT",
