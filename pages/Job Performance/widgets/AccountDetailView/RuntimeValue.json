  "text": "{{\n  (() => {\n    const start = moment(snowplow_jobsDetails.data[0]?.job_slot_redeemed_dt);\n    const end = moment(snowplow_jobsDetails.data[0]?.job_slot_deactivated_dt);\n    if (!start.isValid() || !end.isValid()) return '';\n\n    const today = moment().startOf('day');\n    const daysLeft = end.startOf('day').diff(today, 'days');\n    const suffix = daysLeft >= 0 ? `noch ${daysLeft} Tage` : `${Math.abs(daysLeft)} Tage überfällig`;\n\n    return `${start.format('DD.MM.YYYY')} - ${end.format('DD.MM.YYYY')} (${suffix})`;\n  })()\n}}\n",
