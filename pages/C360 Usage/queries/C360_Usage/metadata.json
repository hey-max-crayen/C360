            "condition": "AND"
          },
          "data": "{\n\t\"condition\": \"AND\",\n\t\"children\": {{\n\t\t(() => {\n\t\t\t// Priorität 1: Nach user_owner_name filtern\n\t\t\tif (appsmith.store.userName !== \"\") {\n\t\t\t\t// Wenn der Name gesetzt ist, NUR danach filtern.\n\t\t\t\treturn [{\n\t\t\t\t\t\"key\": \"user_owner_name\",\n\t\t\t\t\t\"condition\": \"CONTAINS\",\n\t\t\t\t\t\"value\": appsmith.store.userName\n\t\t\t\t}];\n\t\t\t}\n\t\t\t// Priorität 2: Wenn Name leer, nach user_team filtern\n\t\t\telse if (appsmith.store.userTeam !== \"\") {\n\t\t\t\t// Wenn das Team gesetzt ist, NUR danach filtern.\n\t\t\t\treturn [{\n\t\t\t\t\t\"key\": \"user_team\",\n\t\t\t\t\t\"condition\": \"CONTAINS\",\n\t\t\t\t\t\"value\": appsmith.store.userTeam\n\t\t\t\t}];\n\t\t\t}\n\t\t\t// Priorität 3: Wenn auch Team leer, nach user_motion filtern\n\t\t\telse if (appsmith.store.userMotion !== \"\") {\n\t\t\t\t// Wenn die Motion gesetzt ist, NUR danach filtern.\n\t\t\t\treturn [{\n\t\t\t\t\t\"key\": \"motion\",\n\t\t\t\t\t\"condition\": \"CONTAINS\",\n\t\t\t\t\t\"value\": appsmith.store.userMotion\n\t\t\t\t}];\n\t\t\t}\n\t\t\t// Fallback: Wenn alle Suchfelder leer sind\n\t\t\telse {\n\t\t\t\t// Standardfilter anwenden.\n\t\t\t\treturn [{\n\t\t\t\t\t\"key\": \"user_motion\",\n\t\t\t\t\t\"condition\": \"NOT_EQ\",\n\t\t\t\t\t\"value\": \"0\"\n\t\t\t\t}];\n\t\t\t}\n\t\t})()\n\t}}\n}",
